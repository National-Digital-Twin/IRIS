{
    "name": "iris",
    "version": "1.8.0",
    "scripts": {
        "ng": "ng",
        "start": "ng serve --configuration=local --host=0.0.0.0",
        "start:dev": "ng serve --configuration=dev",
        "start:prod": "ng serve --configuration=production",
        "build": "ng build --output-path dist/iris",
        "build:dev": "ng build --configuration=dev",
        "build:local": "npm run config && ng build --configuration=local",
        "test": "jest --coverage",
        "test:watch": "jest --watch",
        "watch": "ng build --watch --configuration development",
        "lint:app": "ng lint",
        "lint:app-fix": "ng lint --fix",
        "lint:styles": "stylelint \"**/*.scss\"",
        "lint:styles-fix": "stylelint \"**/*.scss\" --fix",
        "prepare": "husky",
        "compodoc": "npx compodoc -p tsconfig.doc.json -a screenshots -n \"IRIS documentation\" -s -o",
        "config": "ts-node -O '{\"module\": \"commonjs\"}' ./scripts/config.index.ts"
    },
    "private": true,
    "dependencies": {
        "@angular/animations": "21.2.0",
        "@angular/cdk": "21.2.0",
        "@angular/common": "21.2.0",
        "@angular/compiler": "21.2.0",
        "@angular/core": "21.2.0",
        "@angular/forms": "21.2.0",
        "@angular/material": "21.2.0",
        "@angular/material-moment-adapter": "21.2.0",
        "@angular/platform-browser": "21.2.0",
        "@angular/platform-browser-dynamic": "21.2.0",
        "@angular/router": "21.2.0",
        "@mapbox/mapbox-gl-draw": "1.5.1",
        "@turf/bbox": "7.3.4",
        "@turf/boolean-within": "7.3.4",
        "@turf/helpers": "7.3.4",
        "@turf/intersect": "7.3.4",
        "@turf/points-within-polygon": "7.3.4",
        "angular-plotly.js": "20.0.0",
        "file-saver": "2.0.5",
        "install": "0.13.0",
        "jszip": "3.10.1",
        "mapbox-gl": "3.19.0",
        "modern-normalize": "3.0.1",
        "plotly.js-dist-min": "3.4.0",
        "proj4": "2.20.3",
        "rxjs": "7.8.2",
        "tslib": "2.8.1",
        "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
        "zone.js": "0.16.1"
    },
    "devDependencies": {
        "@angular-eslint/builder": "21.2.0",
        "@angular-eslint/eslint-plugin": "21.2.0",
        "@angular-eslint/eslint-plugin-template": "21.2.0",
        "@angular-eslint/schematics": "21.2.0",
        "@angular-eslint/template-parser": "21.2.0",
        "@angular/build": "21.2.0",
        "@angular/cli": "21.2.0",
        "@angular/compiler-cli": "21.2.0",
        "@commitlint/cli": "20.4.2",
        "@commitlint/config-conventional": "20.4.2",
        "@compodoc/compodoc": "1.2.1",
        "@types/file-saver": "2.0.7",
        "@types/geojson": "7946.0.16",
        "@types/jest": "30.0.0",
        "@types/mapbox__mapbox-gl-draw": "1.4.9",
        "@types/mapbox-gl": "3.4.1",
        "@types/papaparse": "5.5.2",
        "@types/plotly.js-dist-min": "2.3.4",
        "@types/proj4": "2.5.6",
        "@typescript-eslint/eslint-plugin": "8.56.1",
        "@typescript-eslint/parser": "8.56.1",
        "eslint": "9.35.0",
        "eslint-config-prettier": "10.1.8",
        "eslint-plugin-import": "2.32.0",
        "eslint-plugin-prettier": "5.5.5",
        "husky": "9.1.7",
        "jest": "30.2.0",
        "jest-preset-angular": "16.1.1",
        "prettier": "3.8.1",
        "prettier-eslint": "16.4.2",
        "stylelint": "17.4.0",
        "stylelint-config-clean-order": "8.0.1",
        "stylelint-config-recommended-scss": "17.0.0",
        "ts-node": "10.9.2",
        "typescript": "5.9.3"
    }
}
