FROM python:3.12

# Create a non-root user and group
RUN groupadd -r adapteruser && useradd -r -g adapteruser adapteruser

WORKDIR /app

COPY requirements-kafka.txt .
RUN pip install --no-cache-dir -r requirements-kafka.txt

COPY src/kafka_producer.py .

USER adapteruser

ENV PYTHONUNBUFFERED=1
ENV PYTHONPATH=/app

ENV TOPIC_MAPPINGS_FILEPATH=/app/topic_mappings.json

CMD ["python", "./kafka_producer.py"]